# ─────────────────────────────────────────────────────────────────────
# CORE CONFIG
# ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
PORT=8001
DATABASE_URL=mongodb+srv://user:pass@cluster.mongodb.net/hive_pixel_office

# ─────────────────────────────────────────────────────────────────────
# AUTH
# ─────────────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ─────────────────────────────────────────────────────────────────────
# OPENAI / CLAUDE (for Queen + Cobranza Strategy)
# ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─────────────────────────────────────────────────────────────────────
# VOICE ORCHESTRATOR (Assembly AI + Twilio + TTS)
# ─────────────────────────────────────────────────────────────────────

# Assembly AI (speech-to-text, ~200-300ms latency)
ASSEMBLY_AI_API_KEY=...

# Twilio (phone provider)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1234567890
VOICE_WEBHOOK_HOST=https://your-domain.com

# TTS Provider (choose one: "google-cloud", "elevenlabs", "azure", "twilio", "mock")
TTS_PROVIDER=google-cloud

# Google Cloud TTS (if TTS_PROVIDER=google-cloud)
# Generate credentials JSON, then: cat creds.json | base64 -w 0 > creds.b64
GOOGLE_CLOUD_TTS_CREDENTIALS_JSON=eyJh...
GOOGLE_CLOUD_TTS_PROJECT_ID=your-gcp-project

# Elevenlabs TTS (if TTS_PROVIDER=elevenlabs)
# ELEVENLABS_API_KEY=sk-...
# ELEVENLABS_VOICE_ID=default

# Azure Speech TTS (if TTS_PROVIDER=azure)
# AZURE_SPEECH_KEY=...
# AZURE_SPEECH_REGION=eastus

# Enable/disable voice orchestrator
VOICE_ORCHESTRATOR_ENABLED=true

# ─────────────────────────────────────────────────────────────────────
# PHASE 16: WhatsApp (optional)
# ─────────────────────────────────────────────────────────────────────
# WHATSAPP_CHANNEL_ID=...
# WHATSAPP_API_KEY=...

# ─────────────────────────────────────────────────────────────────────
# PHASE 17: Cobranza (Debt Collection)
# ─────────────────────────────────────────────────────────────────────
# VAPI_API_KEY=... (legacy, kept for fallback)
# VAPI_ASSISTANT_ID=...
# VAPI_PHONE_NUMBER_ID=...

# ─────────────────────────────────────────────────────────────────────
# EMAIL (Phase 15)
# ─────────────────────────────────────────────────────────────────────
# SMTP_SERVER=...
# SMTP_PORT=...
# SMTP_USER=...
# SMTP_PASSWORD=...
