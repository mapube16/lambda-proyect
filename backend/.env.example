# OpenAI API Key (required for real agent execution)
OPENAI_API_KEY=sk-your-api-key-here

# Optional: Custom model
# OPENAI_MODEL=gpt-4o-mini

# MailerSend (transactional email — lead outreach, welcome, staff summaries)
MAILERSEND_API_KEY=mlsn.your-api-key-here
MAILERSEND_FROM_EMAIL=noreply@tudominio.com   # Must be a verified sender domain in MailerSend
MAILERSEND_STAFF_EMAIL=staff@isomorph.co      # Receives config summaries when clients are onboarded

# Landa Email Sender (Phase 13)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Landa WhatsApp Sender (Phase 13)
WA_TOKEN=
WA_PHONE_ID=
