# ========================================================================
# Environment Configuration Template for Hive Pixel Office
# ========================================================================
# CRITICAL: This file serves as a TEMPLATE only. Do NOT commit actual secrets!
# Copy this file to .env and fill in REAL values for your environment.
# NEVER commit .env to git - it is in .gitignore for your safety.

# ── REQUIRED SECURITY VARIABLES ────────────────────────────────────────

# JWT Secret Key for token signing (CRITICAL - MUST be set in production)
# Generate a strong key with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# This key is used to sign and verify JWT authentication tokens
SECRET_KEY=YOUR_GENERATED_SECRET_KEY_HERE

# Fernet encryption key for OAuth token storage
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=YOUR_FERNET_KEY_HERE

# ── OpenAI LLM (required for agent execution) ──────────────────────────
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_API_KEY_HERE
# Optional: Custom model (defaults to gpt-4-turbo)
# OPENAI_MODEL=gpt-4o-mini

# ── Database (MongoDB Atlas) ───────────────────────────────────────────
# Format: mongodb+srv://username:password@cluster.mongodb.net/?appName=YourApp
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster.mongodb.net/?appName=Cluster0
MONGODB_DB=hive_office

# ── Email Service (MailerSend) ─────────────────────────────────────────
MAILERSEND_API_KEY=mlsn.YOUR_MAILERSEND_API_KEY_HERE
MAILERSEND_FROM_EMAIL=noreply@yourdomain.com
MAILERSEND_STAFF_EMAIL=staff@yourdomain.com
# Webhook secret for MailerSend signature validation (SECURITY)
MAILERSEND_WEBHOOK_SECRET=YOUR_MAILERSEND_WEBHOOK_SECRET_HERE

# ── Google OAuth (Gmail/Outlook) ───────────────────────────────────────
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY_HERE
# Optional: Google Calendar
GOOGLE_CALENDAR_ID=your-email@gmail.com
# GOOGLE_REFRESH_TOKEN=optional-refresh-token

# ── Vapi Voice Agent (Cobranza/Debt Collection) ────────────────────────
VAPI_API_KEY=YOUR_VAPI_API_KEY_HERE
VAPI_ASSISTANT_ID=YOUR_ASSISTANT_ID_HERE
VAPI_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID_HERE
# Webhook secret for Vapi signature validation (SECURITY - CRITICAL)
VAPI_WEBHOOK_SECRET=YOUR_VAPI_WEBHOOK_SECRET_HERE

# ── Twilio (WhatsApp) ──────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID_HERE
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN_HERE
TWILIO_FROM_NUMBER=whatsapp:+1234567890
TWILIO_WHATSAPP_FROM=whatsapp:+1234567890
TWILIO_TEMPLATE_PROSPECT_SELECT=HX_TEMPLATE_SID_HERE
TWILIO_TEMPLATE_CHANNEL_SELECT=HX_TEMPLATE_SID_HERE
TWILIO_TEMPLATE_CONFIRMATION=HX_TEMPLATE_SID_HERE

# ── Additional APIs ────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-YOUR_OPENROUTER_API_KEY_HERE
SERPER_API_KEY=YOUR_SERPER_API_KEY_HERE
BRIGHT_DATA_API_KEY=YOUR_BRIGHT_DATA_API_KEY_HERE

# ── Application Configuration ──────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
OAUTH_REDIRECT_BASE_URL=http://localhost:5173

# ── Sender Information ────────────────────────────────────────────────
SENDER_NAME=Your Name
SENDER_COMPANY=Your Company
SENDER_PHONE=+1234567890
WA_STAFF_NUMBERS=+1234567890,+1234567891

# ── JWT Configuration ─────────────────────────────────────────────────
# Token expiration time in minutes (15 min recommended for security)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# ── Phase 25: Agentic Multi-Tenant Architecture ────────────────────────────
# Google Gemini Live (voice LLM — consumed in 25-03)
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE
# Telnyx telephony (replacing Twilio — consumed in 25-03)
TELNYX_API_KEY=YOUR_TELNYX_API_KEY_HERE
TELNYX_CONNECTION_ID=YOUR_TELNYX_CONNECTION_ID_HERE
TELNYX_VOICE_PHONE_NUMBER=+1234567890
# Pinecone vector store for per-tenant RAG (consumed in 25-04)
PINECONE_API_KEY=YOUR_PINECONE_API_KEY_HERE
PINECONE_INDEX_NAME=cobranza-rag
# Upstash Redis for config cache (5-min TTL + immediate invalidation — CACHE-01)
# Use rediss:// (SSL) for Upstash; plain redis:// for Railway/local
UPSTASH_REDIS_URL=rediss://YOUR_UPSTASH_REDIS_URL_HERE

# ========================================================================
# SECURITY GUIDELINES:
# ========================================================================
# 1. NEVER commit .env - it is gitignored
# 2. Only .env.example (this template) should be in version control
# 3. Rotate secrets regularly
# 4. Use environment-specific values for dev/staging/prod
# 5. Enable webhook signature validation on all third-party services
# 6. Generate strong keys using Python secrets module
# 7. Store secrets in secure vaults (AWS Secrets Manager, HashiCorp, etc)
# 8. Monitor API key usage for unauthorized access
# ========================================================================

